# LLM
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_FAST_MODEL=google/gemini-2.5-flash
OPENROUTER_REASONING_EFFORT=medium   # для thinking-моделей: low | medium | high
OPENROUTER_REASONING_MAX_TOKENS=4000 # лимит reasoning-токенов

# DeepSeek (нативный API, без OpenRouter)
PRIMARY_MODEL_PROVIDER=openrouter        # openrouter | deepseek
DEEPSEEK_API_KEY=                        # обязательно при PRIMARY_MODEL_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro           # deepseek-v4-pro | deepseek-v4-flash | deepseek-chat | deepseek-reasoner

# OpenAI (STT)
OPENAI_API_KEY=

# Google GenAI (TTS)
GOOGLE_GENAI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Memory
MEM0_API_KEY=

# Search
BRAVE_SEARCH_API_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://node1.serverix.cloud:3046/auth/google/callback

# Infra
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
DATABASE_URL=postgresql://...neon.tech/opekun

# Logging
LOG_LEVEL=info

# Misc
NODE_ENV=development
DEFAULT_TIMEZONE=Asia/Almaty
