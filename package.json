{
  "name": "opekun",
  "version": "0.1.0",
  "description": "AI-nanny Telegram bot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external",
    "postinstall": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run && vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.5.0",
    "@neondatabase/serverless": "^1.0.0",
    "@openrouter/ai-sdk-provider": "^2.5.0",
    "@tavily/core": "^0.7.2",
    "@types/express": "^5.0.6",
    "ai": "^6.0.0",
    "bullmq": "^5.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.44.0",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "grammy": "^1.38.0",
    "ioredis": "^5.0.0",
    "jsdom": "^26.0.0",
    "mammoth": "^1.12.0",
    "mem0ai": "latest",
    "openai": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.0.0",
    "tsx": "^4.0.0",
    "twilio": "^5.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  }
}
