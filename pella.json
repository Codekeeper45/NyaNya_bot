{
  "name": "opekun",
  "runtime": "node20",
  "build": "npm ci && npm run build",
  "start": "node dist/index.js",
  "env_required": [
    "OPENROUTER_API_KEY",
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_ALLOWED_USER_IDS",
    "UPSTASH_REDIS_URL",
    "DATABASE_URL"
  ],
  "env_optional": [
    "OPENAI_API_KEY",
    "MEM0_API_KEY",
    "BRAVE_SEARCH_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_OAUTH_REDIRECT_URI",
    "OPENROUTER_PRIMARY_MODEL",
    "OPENROUTER_FAST_MODEL",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN",
    "TWILIO_FROM_NUMBER",
    "TWILIO_WEBHOOK_URL",
    "CALL_SERVER_PORT",
    "LOG_LEVEL",
    "NODE_ENV",
    "DEFAULT_TIMEZONE"
  ]
}
